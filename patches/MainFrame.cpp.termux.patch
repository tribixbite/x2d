+    wxSize disp_size = wxDisplay(0u).GetClientArea().GetSize();
+    if (disp_size.GetWidth() > 0 && disp_size.GetHeight() > 0) {
+        min_size.x = std::min(min_size.x, disp_size.GetWidth());
+        min_size.y = std::min(min_size.y, disp_size.GetHeight());
+    }
 
