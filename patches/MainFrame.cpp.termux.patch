+
+    // x2d/termux #79 — Ctrl+Shift+L toggles the Plater sidebar visibility.
+    // Lets phone-portrait users hide the sidebar entirely without trips to
+    // the View menu (which itself doesn't always render right under
+    // termux-x11). Re-shows on the same chord.
+    {
+        wxAcceleratorEntry sidebar_toggle_entry;
+        sidebar_toggle_entry.Set(wxACCEL_CTRL | wxACCEL_SHIFT, (int)'L',
+                                 wxID_HIGHEST + 9979);
+        wxAcceleratorTable sidebar_accel(1, &sidebar_toggle_entry);
+        SetAcceleratorTable(sidebar_accel);
+        Bind(wxEVT_MENU, [this](wxCommandEvent&) {
+            if (!m_plater) return;
+            auto& sb = m_plater->sidebar();
+            if (sb.IsShown()) {
+                sb.Hide();
+            } else {
+                sb.Show();
+            }
+            m_plater->Layout();
+        }, wxID_HIGHEST + 9979);
+    }

