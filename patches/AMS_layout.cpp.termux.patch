-#define PAGE_MIN_WIDTH FromDIP(574)
+// x2d/termux #87 — was FromDIP(574). Default upstream value assumes a
+// ≥1400px-wide display: left rail (200) + camera (574) + control (574)
+// > 1080. On a 1080-wide phone display the right control panel was
+// clipped — only AMS slot 1 was visible. Reducing to 360 lets all 4 AMS
+// slots fit (after companion AMSControl.cpp width patch). Camera panel
+// also tightens but the live-feed bitmap rescales fine.
+#define PAGE_MIN_WIDTH FromDIP(360)
