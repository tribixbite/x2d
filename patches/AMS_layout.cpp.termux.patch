+    // x2d/termux #87 — was proportion 0 (fixed width = control panel's min
+    // size). On 1080-wide phone displays the camera panel (proportion 1)
+    // greedily takes ~720px and the control panel only gets ~280px, which
+    // clips the AMS strip to 1-2 of 4 slots. Switching to proportion 1
+    // makes camera and control split the available width evenly (about
+    // 540px each on 1080), and AMS_CANS_WINDOW_SIZE 320dip + 4×80dip
+    // slot widths fit cleanly.
+    bSizer_status_below->Add(m_machine_ctrl_panel, 1, wxALL | wxEXPAND, 0);
 
