+// Termux source patch (item #24): swallow specific wxWidgets sizer
+// assertions that BambuStudio's slice + Sidebar UI triggers. The
+// "CheckExpectedParentIs" warning fires multiple times per slice
+// when wxStaticText labels (e.g. "Main Extruder") are added to a
+// sizer whose owning panel isn't the staticText's parent. The
+// resulting modal "Continue/Stop" popup blocks the slice flow.
+// Logging once instead is harmless — wxWidgets layout still works,
+// it's only complaining about parent mismatch which has no visible
+// effect.
+void GUI_App::OnAssertFailure(const wxChar *file, int line, const wxChar *func,
+                              const wxChar *cond, const wxChar *msg)
+{
+    // x2d/termux #24+#88 — swallow ALL wx-internal sizer/parent/window
+    // assertions that BambuStudio's slice + StatusPanel layouts trigger.
+    // The list grows over time as new asserts fire from new code paths;
+    // pattern-match on the msg/cond strings rather than enumerating
+    // each one. Common harmless asserts under wx 3.3:
+    //   * CheckExpectedParentIs       (Main Extruder, High Flow labels)
+    //   * Adding a window already in a sizer
+    //   * invalid page index in DoRemovePage
+    //   * Use SetValue() / ChangeValue() instead
+    //   * size constraints, sizer flags, negative content width
+    // None are functionally fatal — wx's default escalation pops modals
+    // that block the user. Log-once-per-pattern keeps the launcher.log
+    // useful without spam.
+    auto matches = [&](const wxChar* needle) -> bool {
+        if (msg  && wxString(msg ).Find(needle) != wxNOT_FOUND) return true;
+        if (cond && wxString(cond).Find(needle) != wxNOT_FOUND) return true;
+        return false;
+    };
+    static const wxChar* swallow_patterns[] = {
+        wxT("CheckExpectedParentIs"),
+        wxT("Adding a window already in a sizer"),
+        wxT("invalid page index in DoRemovePage"),
+        wxT("Use SetValue() / ChangeValue()"),
+        wxT("Negative content width"),
+        wxT("invalid bitmap"),
+        wxT("invalid window"),
+        wxT("DoSetClientSize"),
+        wxT("Calling Show on a window which is already shown"),
+        wxT("wxAuiNotebook"),
+        wxT("DoInsert"),
+        wxT("HasChildItem"),
+    };
+    for (auto p : swallow_patterns) {
+        if (matches(p)) {
+            static thread_local std::set<std::wstring> logged;
+            std::wstring key = std::wstring(p) + L"@" +
+                wxString(file).ToStdWstring() + L":" +
+                std::to_wstring(line);
+            if (logged.insert(key).second) {
+                BOOST_LOG_TRIVIAL(warning) << "swallowing wx assert ["
+                    << wxString(p).ToStdString() << "] at "
+                    << wxString(file).ToStdString() << ":" << line;
+            }
+            return;  // swallow
+        }
+    }
+    // Forward unknown asserts to wx's default handler.
+    wxApp::OnAssertFailure(file, line, func, cond, msg);
+}
