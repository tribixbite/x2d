-#ifndef __APPLE__
+// x2d/termux #88 — was `size = size * 4 / 5` on non-Apple platforms,
+// which renders all Body_X / Head_X 20% smaller than their stated size.
+// Designed for higher-DPI Windows displays where 8pt text was the norm.
+// Phone displays at ~180 DPI show this as tiny / unreadable. Removing
+// the shrink boosts everything ~25% which is the right balance for the
+// S25U at native portrait orientation. Layout still fits because the
+// shrink was so small to begin with — most BS sizing uses FromDIP not
+// the raw font height. Apple kept its full size (no #ifdef branch).
+#if defined(__APPLE__) || 1
+    // intentional no-op — leave size at stated value
+#else
     size = size * 4 / 5;
 #endif
 
