diff --git a/src/slic3r/GUI/GLCanvas3D.cpp b/src/slic3r/GUI/GLCanvas3D.cpp
index 0000000..0000001 100644
--- a/src/slic3r/GUI/GLCanvas3D.cpp	2026-04-20 03:03:29.485983014 -0400
+++ b/src/slic3r/GUI/GLCanvas3D.cpp	2026-05-05 06:05:08.462999990 -0400
@@ -1625,6 +1625,21 @@
     //    wxGetApp().plater()->enable_wireframe(false);
     m_initialized = true;
 
+    // x2d/termux #103 — paint events that fired BEFORE the GL context
+    // was ready will have hit the `else` branch in on_paint() and
+    // called render() directly, but render() bails on
+    // !_is_shown_on_screen() / !_set_current() / !init() and never
+    // re-arms. The wx event loop won't redeliver the paint, so the
+    // canvas can stay blank forever even after the context becomes
+    // ready. After init() finally succeeds, post a refresh + dirty
+    // mark so the next idle tick does a full render. Cheap one-shot
+    // post; harmless on non-termux platforms where init usually
+    // succeeds on the first paint anyway.
+    if (m_canvas != nullptr) {
+        m_dirty = true;
+        m_canvas->Refresh();
+        m_canvas->Update();
+    }
     return true;
 }
 
@@ -6571,7 +6586,17 @@
 
 bool GLCanvas3D::_is_shown_on_screen() const
 {
-    return (m_canvas != nullptr) ? m_canvas->IsShownOnScreen() : false;
+    // x2d/termux #85+#86 — IsShownOnScreen() walks up the widget tree
+    // and queries the X server for compositor/EWMH visibility info,
+    // which is unreliable under termux-x11 (no compositor to ask).
+    // Falling back to the local m_canvas widget IsShown() check is
+    // sufficient: if the wxGLCanvas itself is Show()'d its parent
+    // chain has been laid out and a render here is the right thing
+    // to do. The render() entry guards against m_canvas == null and
+    // not-yet-initialised contexts further down, so being a bit
+    // permissive here just means a few wasted GL_INVALID_OP calls
+    // in the worst case rather than a permanently-blank viewport.
+    return (m_canvas != nullptr) && m_canvas->IsShown();
 }
 
 // Getter for the const char*[]
@@ -7581,7 +7606,40 @@
         return false;
     }
     if (m_dirty_context || force_update) {
-        const auto rt = m_canvas->SetCurrent(*m_context);
+        // x2d/termux #86 — ensure the canvas has a real (non-zero,
+        // non-negative) size before SetCurrent. wxGLCanvasEGL refuses
+        // to allocate a window surface for a 0-or-negative-sized
+        // canvas. Under termux-x11 the canvas's initial size is
+        // stale (-128 x -48 type values) until the first parent
+        // Layout pass — but the early calls to render() happen
+        // BEFORE that layout, so the canvas is permanently stuck.
+        // Force-size it from the parent's client area to unblock
+        // the EGL surface allocation.
+        wxSize cs = m_canvas->GetClientSize();
+        if (cs.x <= 0 || cs.y <= 0) {
+            wxWindow* p = m_canvas->GetParent();
+            wxSize ps = p ? p->GetClientSize() : wxSize(800, 600);
+            if (ps.x > 0 && ps.y > 0) {
+                m_canvas->SetSize(ps);
+            }
+        }
+        auto rt = m_canvas->SetCurrent(*m_context);
+        if (!rt) {
+            // x2d/termux #86 — recreate the wxGLContext lazily on
+            // first failure. Some EGL backends bind the context to
+            // the canvas's surface state at construction time; if
+            // the canvas wasn't realized then, recreating with the
+            // now-realized canvas can give us a usable context.
+            // Single-shot retry — if this still fails the issue is
+            // a wx-level wxGLCanvasEGL surface-binding bug under
+            // termux-x11 that needs a wxWidgets rebuild to fix.
+            static int retry_count = 0;
+            if (retry_count++ < 2) {
+                delete m_context;
+                m_context = new wxGLContext(m_canvas);
+                rt = m_canvas->SetCurrent(*m_context);
+            }
+        }
         if (rt) {
             m_dirty_context = false;
         }
