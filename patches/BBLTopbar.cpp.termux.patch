-        HWND hWnd = m_frame->GetHandle();
-        RECT      borderThickness;
-        SetRectEmpty(&borderThickness);
-        AdjustWindowRectEx(&borderThickness, GetWindowLongPtr(hWnd, GWL_STYLE), FALSE, 0);
-        m_frame->SetMaxSize(size + wxSize{-borderThickness.left + borderThickness.right, -borderThickness.top + borderThickness.bottom});
-#endif //  __WXMSW__
-        m_normalRect = m_frame->GetRect();
-        m_frame->Maximize();
-    }
+    HWND hWnd = m_frame->GetHandle();
+    RECT      borderThickness;
+    SetRectEmpty(&borderThickness);
+    AdjustWindowRectEx(&borderThickness, GetWindowLongPtr(hWnd, GWL_STYLE), FALSE, 0);
+    m_frame->SetMaxSize(area.GetSize() + wxSize{-borderThickness.left + borderThickness.right, -borderThickness.top + borderThickness.bottom});
+    m_frame->Maximize();
+#else
+    // Ask the WM to maximize first (cheap, works on real desktops). Then
+    // unconditionally force the geometry so we still end up correctly sized
+    // when the WM is absent or non-EWMH-compliant (termux-x11).
+    //
+    // Min-size relaxation: BambuStudio's MainFrame sets a min-size of
+    // (max(1000, 76*em), max(600, 49*em)). On a portrait phone display the
+    // X server's width is often <1000px; SetSize would then snap to the
+    // min-size and the window would extend off the right edge. Drop the
+    // min-size to the display area itself for the duration of the maximize
+    // and restore it on un-maximize. Saving lets us roundtrip without
+    // hard-coding the original.
+    m_saved_min_size = m_frame->GetMinSize();
+    m_frame->SetMinSize(area.GetSize());
+    m_frame->Maximize();
+    m_frame->SetSize(area);
+    m_frame->Move(area.GetTopLeft());
+    m_manual_maximized = true;
+    SetWindowSize();          // swap toolbar icon to "restore"
+#endif
 }
 
