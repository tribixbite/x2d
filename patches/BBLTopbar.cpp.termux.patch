+
+    bool was_max = m_frame->IsMaximized() || m_manual_maximized;
+    if (was_max) {
+        m_manual_maximized = false;
+        if (m_frame->IsMaximized())
+            m_frame->Restore();
+        // Restore the min-size we temporarily relaxed in the maximize path.
+        if (m_saved_min_size.GetWidth() > 0 && m_saved_min_size.GetHeight() > 0) {
+            m_frame->SetMinSize(m_saved_min_size);
+            m_saved_min_size = wxSize{-1, -1};
+        }
+        if (m_normalRect.GetWidth() > 0 && m_normalRect.GetHeight() > 0) {
+            m_frame->SetSize(m_normalRect);
+        }
+        SetMaximizedSize();   // swap toolbar icon back to "maximize"
+        return;
     }
-    else {
-        wxDisplay display(this);
-        auto      size = display.GetClientArea().GetSize();
+
+    m_normalRect = m_frame->GetRect();
